# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3000

# Free LLM for deal suggestions — get key at console.groq.com (no credit card)
GROQ_API_KEY=your-groq-api-key-here

# From your Azure AD app registration
AZURE_AD_CLIENT_ID=your-client-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here

# Use "common" to allow any Microsoft account (personal + work)
# Or set to your specific tenant ID to restrict to your org
AZURE_AD_TENANT_ID=common
